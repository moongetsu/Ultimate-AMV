{
  "name": "ultimate-amv-script",
  "private": true,
  "version": "0.10.0",
  "type": "module",
  "scripts": {
    "test": "npm run test:js && npm run test:rust && npm run test:py",
    "test:js": "vitest run",
    "test:js:watch": "vitest",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:py": "pytest backend/",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "predesktop": "powershell -Command \"Remove-Item -Recurse -Force 'src-tauri/target/debug/build/ultimate-amv-script-*' -ErrorAction SilentlyContinue\"",
    "desktop": "tauri dev"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-updater": "^2",
    "@vitejs/plugin-react": "^5.1.1",
    "hls.js": "^1.6.16",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-virtuoso": "^4.14.1",
    "vite": "^7.2.7",
    "wavesurfer.js": "^7.12.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
