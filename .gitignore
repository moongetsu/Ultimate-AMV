# Logs and temporary files. `logs/` is anchored so it doesn't shadow
# src/features/logs/ : the rule below already covers backend/logs/.
*.log
/logs/
tmp/
temp/
*.tmp
temp.txt
temp.md

# Agent-generated scratch reports at repo root. Local-only.
/TEST_AGENT_PROMPT.md
/TEST_FAILURES.md
/TEST_SUMMARY.md

