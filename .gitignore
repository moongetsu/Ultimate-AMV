__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
dist/
build/
*.spec

# Node / frontend.
node_modules/
.npm/
.pnpm-store/
coverage/

# Tauri / Rust.
target/
src-tauri/target/
src-tauri/gen/

# App-generated media and model artifacts.
downloads/
output/
outputs/
exports/
# Anchored : the runtime clip output dir lives at the project root, but
# src/features/clips/ holds source code and must stay tracked.
/clips/
episodes/
models/
backend/models/
backend/config.json
backend/audio_history.json
backend/app_logs.json
backend/logs/
